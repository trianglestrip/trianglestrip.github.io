  "integration_approaches": [
    {
      "id": "hotboard-cli",
      "name": "hotboard CLI（当前主方案）",
      "repo": "https://github.com/hotboard/hotboard",
      "pypi": "hotboard",
      "pros": [
        "Python 与 fetch-hot.py 同栈，subprocess 即可",
        "47 个平台，JSON 输出格式统一",
        "无自建服务，GitHub Actions cron 友好"
      ],
      "cons": [
        "平台数少于 DailyHotApi / NewsNow",
        "部分源（hostloc、linuxdo、nytimes）网络不稳定",
        "gameres 等源可能长期 0 条"
      ],
      "fit": "primary"
    },
    {
      "id": "dailyhot-api",
      "name": "DailyHotApi（HTTP 聚合 API）",
      "repo": "https://github.com/imsyy/DailyHotApi",
      "demo": "https://api-hot.imsyy.top",
      "pros": [
        "60+ 平台，含 coolapk、hostloc、linux.do",
        "统一 REST：`GET /{platform}`，支持 RSS",
        "社区活跃（3k+ stars），TypeScript 易读源码补 driver"
      ],
      "cons": [
        "需自建 Docker/Vercel 或依赖公共实例（稳定性不可控）",
        "响应格式与 hotboard 不同，需写 adapter",
        "公共 API 有 rate limit / 下线风险"
      ],
      "fit": "secondary",
      "adapter_sketch": "hot-sources.json 增加 driver: dailyhot_api, base_url + path"
    },
    {
      "id": "dailyhot-api-go",
      "name": "DailyHotApi-Go",
      "repo": "https://github.com/ShellMonster/DailyHotApi-Go",
      "pros": [
        "DailyHotApi 的 Go 重构，61 渠道，性能更好",
        "含 The Guardian、Economist 等国际源"
      ],
      "cons": [
        "需单独部署 Go 服务",
        "与现有 Python CI 多一层运维"
      ],
      "fit": "optional_self_host"
    },
    {
      "id": "newsnow",
      "name": "NewsNow",
      "repo": "https://github.com/ourongxing/newsnow",
      "demo": "https://newsnow.busiyi.world",
      "pros": [
        "20k+ stars，完整前后端 + 40+ 源",
        "自适应抓取间隔、MCP server",
        "sources 定义清晰，可参考移植"
      ],
      "cons": [
        "偏「阅读器产品」而非纯 API",
        "自部署需 Node + DB；直接调 demo 实例不适合生产",
        "源格式需 adapter"
      ],
      "fit": "reference_or_self_host"
    },
    {
      "id": "rss-direct",
      "name": "站点 RSS / 公开 API（当前部分源已用）",
      "examples": ["gcores", "oschina", "qbitai", "producthunt", "nodeseek"],
      "pros": [
        "维护成本最低，无第三方聚合依赖",
        "fetch-hot.py 已有 fetch_rss driver"
      ],
      "cons": [
        "需逐个找 feed，不是所有站都有",
        "部分 RSS 不含热度字段"
      ],
      "fit": "preferred_for_new_sources"
    },
    {
      "id": "rsshub",
      "name": "RSSHub",
      "repo": "https://github.com/DIYgod/RSSHub",
      "pros": [
        "上千路由，可覆盖 tophub 大量长尾源",
        "自托管或使用公共实例"
      ],
      "cons": [
        "公共实例限流；路由随站点改版失效",
        "输出 RSS 需再解析，通常无 hot 数值"
      ],
      "fit": "long_tail"
    },
    {
      "id": "tophub-api",
      "name": "今日热榜·榜眼数据（商业 API）",
      "url": "https://tophub.today/",
      "pros": [
        "与 tophub 同源，覆盖最全",
        "免维护爬虫"
      ],
      "cons": [
        "付费",
        "依赖外部商业服务"
      ],
      "fit": "if_full_parity_needed"
    }
  ],
  "recommendation": {
    "short_term": "维持 hotboard CLI；把 status=ready 的源接入；blocked 源在 CI 复测",
    "medium_term": "新增 dailyhot_api driver，按需补 hostloc/coolapk 等 hotboard 缺口",
