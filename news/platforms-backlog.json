{
  "version": 1,
  "updated_at": "2026-06-12",
  "policy": {
    "forbidden": [
      "禁止从 tophub.today 抓取或转载内容",
      "禁止使用 tophub 榜眼商业 API",
      "禁止以 tophub 作为数据源或对齐目标来决定接入列表"
    ],
    "allowed_sources": [
      "hotboard CLI 直连各平台",
      "站点官方 RSS / 公开 API",
      "自写 fetch driver",
      "自托管 RSSHub（非 tophub）",
      "开源聚合项目源码参考（DailyHotApi、NewsNow 等），数据仍从原站获取"
    ]
  },
  "summary": {
    "live_platforms": 60,
    "live_rss_platforms": 10,
    "live_ref": "data/config.json → order",
    "hotboard_supported": 47,
    "hotboard_gap": 4,
    "custom_drivers_live": 14,
    "custom_drivers_unwired": 2
  },
  "integration_approaches": [
    {
      "id": "hotboard-cli",
      "name": "hotboard CLI（当前主方案）",
      "repo": "https://github.com/hotboard/hotboard",
      "pypi": "hotboard",
      "pros": [
        "Python 与 fetch-hot.py 同栈，subprocess 即可",
        "47 个平台，JSON 输出格式统一",
        "无自建服务，GitHub Actions cron 友好"
      ],
      "cons": [
        "平台数少于 DailyHotApi / NewsNow",
        "部分源（hostloc、linuxdo、nytimes）网络不稳定",
        "gameres 等源可能长期 0 条"
      ],
      "fit": "primary"
    },
    {
      "id": "dailyhot-api",
      "name": "DailyHotApi（HTTP 聚合 API）",
      "repo": "https://github.com/imsyy/DailyHotApi",
      "pros": [
        "60+ 平台，含 coolapk、hostloc、linux.do",
        "统一 REST：`GET /{platform}`，支持 RSS",
        "社区活跃，TypeScript 源码可参考"
      ],
      "cons": [
        "需自建 Docker/Vercel 或依赖公共实例（稳定性不可控）",
        "响应格式与 hotboard 不同，需写 adapter",
        "公共 API 有 rate limit / 下线风险"
      ],
      "fit": "secondary",
      "adapter_sketch": "hot-sources.json 增加 driver: dailyhot_api, base_url + path"
    },
    {
      "id": "dailyhot-api-go",
      "name": "DailyHotApi-Go",
      "repo": "https://github.com/ShellMonster/DailyHotApi-Go",
      "pros": [
        "DailyHotApi 的 Go 重构，61 渠道，性能更好",
        "含 The Guardian、Economist 等国际源"
      ],
      "cons": [
        "需单独部署 Go 服务",
        "与现有 Python CI 多一层运维"
      ],
      "fit": "optional_self_host"
    },
    {
      "id": "newsnow",
      "name": "NewsNow",
      "repo": "https://github.com/ourongxing/newsnow",
      "pros": [
        "20k+ stars，完整前后端 + 40+ 源",
        "sources 定义清晰，可参考移植抓取逻辑"
      ],
      "cons": [
        "偏「阅读器产品」而非纯 API",
        "自部署需 Node + DB",
        "源格式需 adapter"
      ],
      "fit": "reference_or_self_host"
    },
    {
      "id": "rss-direct",
      "name": "站点 RSS / 公开 API（推荐新增源方式）",
      "examples": [
        "gcores",
        "oschina",
        "qbitai",
        "producthunt",
        "nodeseek",
        "solidot",
        "readhub",
        "infoq",
        "chinanews"
      ],
      "pros": [
        "维护成本最低，数据来自原站",
        "fetch-hot.py 已有 fetch_rss driver"
      ],
      "cons": [
        "需逐个找 feed，不是所有站都有",
        "部分 RSS 不含热度字段"
      ],
      "fit": "preferred_for_new_sources"
    },
    {
      "id": "rsshub",
      "name": "RSSHub（自托管）",
      "repo": "https://github.com/DIYgod/RSSHub",
      "pros": [
        "上千路由，可补官方无 RSS 的站点",
        "自托管可控"
      ],
      "cons": [
        "公共实例限流不可用；需自托管",
        "路由随站点改版失效",
        "通常无 hot 数值"
      ],
      "fit": "long_tail_self_hosted"
    }
  ],
  "recommendation": {
    "short_term": "维持 hotboard CLI；接入 status=ready 源；RSS 优先官方 feed",
    "medium_term": "按需自写 driver 或自托管 DailyHotApi / RSSHub",
    "long_term": "按使用价值扩展源，不追求外部聚合站点的数量对齐"
  },
