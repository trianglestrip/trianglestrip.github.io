{
  "name": "live-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "build": "tsc && node scripts/bundle.mjs && node scripts/publish-dist.mjs",
    "dev": "tsx src/index.ts",
    "start": "node ../dist/server/live-api.mjs",
    "typecheck": "tsc --noEmit",
    "sync:cross-map": "tsx scripts/sync-category-cross-map.mjs",
    "sync:douyin-icons": "npm run build && node scripts/sync-douyin-game-icons.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@tars/stream": "^2.0.3",
    "ws": "^8.21.0"
  }
}
